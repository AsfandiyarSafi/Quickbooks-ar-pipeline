# Copy this file to `.env` in the project root and fill in values.
# Never commit `.env`.

# --- Supabase (dashboard + sync target) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- QuickBooks API (sync pipeline) ---
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REFRESH_TOKEN=
QUICKBOOKS_REALM_ID=
# sandbox | production
QUICKBOOKS_ENV=sandbox

# --- One-time OAuth: exchange authorization code for tokens (scripts only) ---
# QUICKBOOKS_AUTH_CODE=
# QUICKBOOKS_REDIRECT_URI=http://localhost:4500/callback
